{
  "permissions": {
    "deny": [
      "Read(docs/zanonimizowane/*.json)",
      "Read(docs/zanonimizowane/**/*.json)",
      "Read(./docs/zanonimizowane/*.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/block-zanonimizowane.sh\""
          }
        ]
      }
    ]
  }
}
